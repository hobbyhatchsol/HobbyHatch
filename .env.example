# HobbyHatch environment variables
# Copy to .env.local for local dev, and set the same in Vercel → Settings → Environment Variables.

# --- Solana RPC (recommended) --------------------------------------------
# Public devnet is used if unset, but it rate-limits hard. Use Helius/QuickNode.
# Example: https://devnet.helius-rpc.com/?api-key=YOUR_KEY
NEXT_PUBLIC_SOLANA_RPC=

# --- Brand ----------------------------------------------------------------
# Optional: point the logo at a raster export instead of the bundled SVG.
NEXT_PUBLIC_LOGO_SRC=

# =========================================================================
# The below are needed for the DB-backed backend + auth (Phase B).
# The app runs on local/mock data until DATABASE_URL is set.
# =========================================================================

# --- Database (Postgres: Neon or Supabase) --------------------------------
# Neon:     postgres://user:pass@ep-xxx.aws.neon.tech/db?sslmode=require
# Supabase: use the "Connection pooling" (pgbouncer) string for serverless.
DATABASE_URL=

# --- Auth (Sign-In With Solana session signing) ---------------------------
# Generate one:  openssl rand -base64 32
AUTH_SECRET=

# --- File uploads (community banner/logo) — pick one ----------------------
# Cloudflare R2 / S3-compatible:
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
R2_PUBLIC_URL=

# --- Waitlist / email (optional) ------------------------------------------
RESEND_API_KEY=
